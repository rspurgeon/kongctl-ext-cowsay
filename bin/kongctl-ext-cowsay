#!/bin/sh
set -eu

WIDTH=40

resolve_kongctl() {
  ctx="${KONGCTL_EXTENSION_CONTEXT:-}"
  if [ -n "$ctx" ] && [ -r "$ctx" ]; then
    path=$(sed -n \
      's/^[[:space:]]*"kongctl_path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' \
      "$ctx")
    if [ -n "$path" ]; then
      printf '%s\n' "$path"
      return
    fi
  fi
  printf 'kongctl\n'
}

json_str() {
  printf '%s\n' "$1" | sed -n 's/.*"'"$2"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1
}

greet_me() {
  kongctl_bin=$(resolve_kongctl)
  if ! json=$("$kongctl_bin" get me --output json 2>/dev/null); then
    echo "kongctl-ext-cowsay: failed to run '$kongctl_bin get me'" >&2
    exit 1
  fi

  name=$(json_str "$json" preferred_name)
  [ -z "$name" ] && name=$(json_str "$json" full_name)
  [ -z "$name" ] && name="friend"

  created=$(json_str "$json" created_at)
  since=${created%%T*}

  if [ -n "$since" ]; then
    printf 'Hello %s\nYou'\''ve been using Konnect since %s!\n' "$name" "$since" | render
  else
    printf 'Hello %s\n' "$name" | render
  fi
}

list_apis() {
  kongctl_bin=$(resolve_kongctl)
  if ! json=$("$kongctl_bin" get apis --output json 2>/dev/null); then
    echo "kongctl-ext-cowsay: failed to run '$kongctl_bin get apis'" >&2
    exit 1
  fi

  names=$(printf '%s\n' "$json" | awk '
    {
      if (depth == 1 && match($0, /"name"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
        v = substr($0, RSTART, RLENGTH)
        sub(/"name"[[:space:]]*:[[:space:]]*"/, "", v)
        sub(/"$/, "", v)
        print v
      }
      n = length($0)
      for (i = 1; i <= n; i++) {
        c = substr($0, i, 1)
        if (c == "{") depth++
        else if (c == "}") depth--
      }
    }
  ')

  if [ -z "$names" ]; then
    printf 'No APIs to show!\n' | render
  else
    seed=$(od -An -N4 -tu4 < /dev/urandom 2>/dev/null | tr -d ' \n')
    : "${seed:=$$}"
    greeting=$(awk -v seed="$seed" 'BEGIN {
      srand(seed)
      n = split("Holy cow, APIs!|Moo! Look what I found:|Udderly fantastic APIs:|Moooove over, APIs incoming!|Hay there! Some APIs:", g, "|")
      print g[int(rand() * n) + 1]
    }')
    {
      printf '%s\n' "$greeting"
      printf '%s\n' "$names" | sed 's/^/- /'
    } | render
  fi
}

render() {
  awk -v width="$WIDTH" '
function repeat(c, n,    s, i) {
  s = ""
  for (i = 0; i < n; i++) s = s c
  return s
}
{
  nf = split($0, words, " ")
  line = ""
  for (i = 1; i <= nf; i++) {
    w = words[i]
    if (w == "") continue
    if (line == "") {
      line = w
    } else if (length(line) + 1 + length(w) <= width) {
      line = line " " w
    } else {
      lines[++nlines] = line
      if (length(line) > maxlen) maxlen = length(line)
      line = w
    }
  }
  lines[++nlines] = line
  if (length(line) > maxlen) maxlen = length(line)
}
END {
  if (nlines == 0) { lines[++nlines] = ""; maxlen = 0 }
  print " " repeat("_", maxlen + 2)
  for (i = 1; i <= nlines; i++) {
    pad = maxlen - length(lines[i])
    if (nlines == 1)      { l = "<"; r = ">" }
    else if (i == 1)      { l = "/"; r = "\\" }
    else if (i == nlines) { l = "\\"; r = "/" }
    else                  { l = "|"; r = "|" }
    printf "%s %s%s %s\n", l, lines[i], repeat(" ", pad), r
  }
  print " " repeat("-", maxlen + 2)
  print "        \\   ^__^"
  print "         \\  (oo)\\_______"
  print "            (__)\\       )\\/\\"
  print "                ||----w |"
  print "                ||     ||"
}
'
}

LITERAL=0

while [ $# -gt 0 ]; do
  case "$1" in
    -W)
      shift
      WIDTH=${1:?-W requires an argument}
      shift
      ;;
    -h|--help)
      cat <<'EOF'
Usage:
  kongctl cowsay [-W width] [--] message...   render message in a speech bubble
  echo message | kongctl cowsay               render piped input
  kongctl cowsay me                           greet the current Konnect user
  kongctl cowsay api                          list APIs from `kongctl get apis`

Use `--` to render a message that starts with a subcommand name like `me`.
EOF
      exit 0
      ;;
    --)
      shift
      LITERAL=1
      break
      ;;
    -*)
      echo "kongctl-ext-cowsay: unknown flag: $1" >&2
      exit 2
      ;;
    *)
      break
      ;;
  esac
done

sub=""
if [ "$LITERAL" -eq 0 ]; then
  sub="${1:-}"
fi

case "$sub" in
  me)
    shift
    if [ $# -ne 0 ]; then
      echo "kongctl-ext-cowsay: 'me' takes no arguments" >&2
      exit 2
    fi
    greet_me
    ;;
  api)
    shift
    if [ $# -ne 0 ]; then
      echo "kongctl-ext-cowsay: 'api' takes no arguments" >&2
      exit 2
    fi
    list_apis
    ;;
  *)
    if [ $# -gt 0 ]; then
      msg="$*"
    elif [ ! -t 0 ]; then
      msg=$(cat)
    else
      msg="moo"
    fi
    printf '%s\n' "$msg" | render
    ;;
esac
